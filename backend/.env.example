PORT=5000
MONGO_URI=mongodb://localhost:27017/viral-idea-app
OPENAI_API_KEY=sk-proj-your-openai-key
JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Email OTP — Option 1 (recommended): Resend API (free, https://resend.com)
RESEND_API_KEY=
RESEND_FROM=ViralAI <you@yourdomain.com>

# Email OTP — Option 2 (fallback): SMTP (e.g. Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# Optional billing configuration
FRONTEND_URL=http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=